# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit it.

# --- ElevenLabs (audio generation) ---
# Needed only for the dev-time audio-gen script, never at runtime.
# API key: https://elevenlabs.io/app/settings/api-keys
# Voice IDs: https://elevenlabs.io/app/voice-lab — pick a voice that
# matches the Narrator profile in docs/AUDIO_SCRIPT.md, and another
# that matches David (the Microsoft-Support scammer).
ELEVENLABS_API_KEY=
ELEVENLABS_NARRATOR_VOICE_ID=
ELEVENLABS_DAVID_VOICE_ID=
# Optional. eleven_multilingual_v2 is the safe default.
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# --- Supabase (event logging + study data) ---
# Create a project at https://supabase.com/dashboard
# Then run supabase/migrations/0001_initial.sql in the SQL Editor.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — only needed for the server-side API route.
# Get it from Project Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenRouter (Track B 100-agent study) ---
# Used by the LLM-driven agent harness (not built yet).
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
